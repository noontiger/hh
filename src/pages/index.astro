---
import '../styles/global.css';
import { profile, experience, projects } from '../data/content.ts';

const initials = profile.name
  .split(' ')
  .map((w) => w[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();

const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);

const themes = [
  { id: 'darkplus', label: 'Dark+', color: '#569cd6', bg: '#1e1e1e' },
  { id: 'lightplus', label: 'Light+', color: '#007acc', bg: '#ffffff' },
  { id: 'solarized-dark', label: 'Solarized Dark', color: '#268bd2', bg: '#002b36' },
  { id: 'monokai', label: 'Monokai', color: '#66d9ef', bg: '#272822' },
  { id: 'github-dark', label: 'GitHub Dark', color: '#58a6ff', bg: '#0d1117' },
  { id: 'github-light', label: 'GitHub Light', color: '#0969da', bg: '#ffffff' },
  { id: 'high-contrast', label: 'High Contrast', color: '#ffd700', bg: '#000000' },
  { id: 'abyss', label: 'Abyss', color: '#6a9cff', bg: '#00002a' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.name} — {profile.headline}</title>
    <meta name="description" content={profile.sub} />
    <meta property="og:title" content={profile.name} />
    <meta property="og:description" content={profile.sub} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Apply saved theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('hh-theme');
          if (t) document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!-- ============ NAV ============ -->
    <nav class="nav">
      <div class="container">
        <a href="#top" class="nav-logo" aria-label="Home">{initials}</a>
        <input type="checkbox" id="nav-toggle" class="nav-toggle" />
        <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </label>
        <div class="nav-links">
          <a class="nav-link" href="#about"><span>01.</span>About</a>
          <a class="nav-link" href="#experience"><span>02.</span>Experience</a>
          <a class="nav-link" href="#projects"><span>03.</span>Projects</a>
          <a class="nav-link" href="#contact"><span>04.</span>Contact</a>

          <details class="theme-wrap" id="theme-wrap">
            <summary class="theme-btn" aria-label="切换主题">
              <span class="theme-icon">🎨</span>
              <span class="theme-current" id="theme-current">Dark+</span>
              <span class="caret">▾</span>
            </summary>
            <div class="theme-menu">
              {
                themes.map((t) => (
                  <button type="button" class="theme-opt" data-theme-value={t.id}>
                    <span class="theme-dot" style={`background:${t.color}`}></span>
                    <span class="theme-label">{t.label}</span>
                  </button>
                ))
              }
            </div>
          </details>

          <a class="btn nav-resume" href={profile.resumeUrl}>Resume</a>
        </div>
      </div>
    </nav>

    <main>
      <!-- ============ HERO ============ -->
      <section class="hero" id="top">
        <div class="container">
          <p class="hero-greet">{profile.greet}</p>
          <h1 class="hero-name">{profile.name}</h1>
          <h2 class="hero-headline">{profile.headline}</h2>
          <p class="hero-sub">{profile.sub}</p>
          <div class="hero-cta">
            <a class="btn" href="#projects">Check out my work</a>
            <a class="btn" href="#contact">Get in touch</a>
          </div>
        </div>
      </section>

      <!-- ============ ABOUT ============ -->
      <section id="about">
        <div class="container">
          <div class="section-head">
            <span class="section-num">01.</span>
            <h2 class="section-title">About</h2>
            <span class="section-line"></span>
          </div>
          <div class="about-grid">
            <div class="about-text">
              {profile.about.map((para) => <p set:html={para} />)}
              <ul class="skills">
                {profile.skills.map((s) => <li>{s}</li>)}
              </ul>
            </div>
            <div class="about-pic">
              <div class="pic-box">YOUR PHOTO HERE</div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ EXPERIENCE ============ -->
      <section id="experience">
        <div class="container">
          <div class="section-head">
            <span class="section-num">02.</span>
            <h2 class="section-title">Experience</h2>
            <span class="section-line"></span>
          </div>
          <div class="exp-list">
            {
              experience.map((job) => (
                <div class="exp-item">
                  <div class="exp-top">
                    <h3 class="exp-role">
                      {job.role} <span class="exp-company">@ {job.company}</span>
                    </h3>
                    <span class="exp-range">{job.range}</span>
                  </div>
                  <p class="exp-location">{job.location}</p>
                  <ul class="exp-points">
                    {job.points.map((pt) => (
                      <li set:html={pt} />
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ============ PROJECTS ============ -->
      <section id="projects">
        <div class="container">
          <div class="section-head">
            <span class="section-num">03.</span>
            <h2 class="section-title">Projects</h2>
            <span class="section-line"></span>
          </div>

          <div class="featured">
            {
              featured.map((p) => (
                <article class="proj-card">
                  <h3 class="proj-name">{p.name}</h3>
                  <p class="proj-desc">{p.description}</p>
                  <ul class="proj-tags">
                    {p.tags.map((t) => (
                      <li>{t}</li>
                    ))}
                  </ul>
                  <div class="proj-links">
                    <a href={p.repo} target="_blank" rel="noopener">GitHub</a>
                    <a href={p.demo} target="_blank" rel="noopener">Live</a>
                  </div>
                </article>
              ))
            }
          </div>

          <div class="proj-grid">
            {
              others.map((p) => (
                <article class="proj-card">
                  <h3 class="proj-name">{p.name}</h3>
                  <p class="proj-desc">{p.description}</p>
                  <ul class="proj-tags">
                    {p.tags.map((t) => (
                      <li>{t}</li>
                    ))}
                  </ul>
                  <div class="proj-links">
                    <a href={p.repo} target="_blank" rel="noopener">GitHub</a>
                    <a href={p.demo} target="_blank" rel="noopener">Live</a>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ============ CONTACT ============ -->
      <section id="contact" class="contact">
        <div class="container">
          <div class="section-head">
            <span class="section-num">04.</span>
            <h2 class="section-title">Contact</h2>
            <span class="section-line"></span>
          </div>
          <p class="contact-sub">My inbox is always open. Whether you have a question or just want to say hello, I'll try my best to get back to you!</p>
          <a class="btn" href={`mailto:${profile.email}`}>Say hello</a>
          <div class="contact-socials">
            {profile.socials.map((s) => (
              <a href={s.url} target="_blank" rel="noopener">{s.name}</a>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        <p>
          Design inspired by{' '}
          <a href="https://github.com/bchiang7/v4" target="_blank" rel="noopener">bchiang7/v4</a>{' '}
          · Built with Astro
        </p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var KEY = 'hh-theme';
        var wrap = document.getElementById('theme-wrap');
        var current = document.getElementById('theme-current');
        var opts = document.querySelectorAll('.theme-opt');

        function labelFor(name) {
          var b = document.querySelector('.theme-opt[data-theme-value="' + name + '"]');
          return b ? b.querySelector('.theme-label').textContent : name;
        }
        function apply(name) {
          document.documentElement.dataset.theme = name;
          try { localStorage.setItem(KEY, name); } catch (e) {}
          if (current) current.textContent = labelFor(name);
        }

        opts.forEach(function (b) {
          b.addEventListener('click', function () {
            apply(b.getAttribute('data-theme-value'));
            if (wrap) wrap.removeAttribute('open');
          });
        });

        // sync label with any theme already applied (e.g. by the anti-FOUC script)
        var saved = document.documentElement.dataset.theme;
        if (saved && current) current.textContent = labelFor(saved);
      })();
    </script>
  </body>
</html>
